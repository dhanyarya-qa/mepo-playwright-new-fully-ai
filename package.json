{
  "name": "mepo-playwright",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright TypeScript automation for https://dev.mepo.travel/",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:update": "playwright test --update-snapshots",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}

